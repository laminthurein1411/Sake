{
	"name": "sake",
	"private": true,
	"version": "0.0.0-dev",
	"type": "module",
	"packageManager": "bun@1.3.8",
	"scripts": {
		"dev": "vite dev",
		"dev:mig": "bun run db:migrate && bun run dev",
		"build": "node ./scripts/run-build-with-project-env.mjs",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "bun test",
		"db:generate": "drizzle-kit generate && node ./scripts/db/normalize-journal-timestamps.mjs",
		"db:migrate": "node ./scripts/db/run-with-project-env.mjs ./node_modules/drizzle-kit/bin.cjs migrate",
		"db:studio": "node ./scripts/db/run-with-project-env.mjs ./node_modules/drizzle-kit/bin.cjs studio",
		"db:baseline:mark": "node ./scripts/db/run-with-project-env.mjs ./scripts/db/mark-drizzle-baseline.mjs",
		"db:status": "node ./scripts/db/run-with-project-env.mjs ./scripts/db/drizzle-status.mjs",
		"db:shelves:check": "node ./scripts/db/run-with-project-env.mjs ./scripts/db/check-shelves-sort-order.mjs",
		"db:keys:dry-run": "node ./scripts/db/run-with-project-env.mjs ./scripts/db/backfill-sanitized-storage-keys.mjs",
		"db:keys:apply": "node ./scripts/db/run-with-project-env.mjs ./scripts/db/backfill-sanitized-storage-keys.mjs --apply",
		"db:keys:dedupe:dry-run": "node ./scripts/db/run-with-project-env.mjs ./scripts/db/backfill-sanitized-storage-keys.mjs --dedupe",
		"db:keys:dedupe:apply": "node ./scripts/db/run-with-project-env.mjs ./scripts/db/backfill-sanitized-storage-keys.mjs --dedupe --apply"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.4.0",
		"@sveltejs/kit": "^2.47.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/cookie": "^0.6.0",
		"@types/estree": "^1.0.8",
		"@types/node": "^24.10.0",
		"@types/resolve": "^1.20.6",
		"drizzle-kit": "^0.31.4",
		"sass-embedded": "^1.97.3",
		"svelte": "^5.41.0",
		"svelte-check": "^4.3.3",
		"typescript": "^5.9.3",
		"vite": "^7.1.10"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.922.0",
		"@libsql/client": "^0.15.15",
		"drizzle-orm": "^0.44.6",
		"jszip": "^3.10.1",
		"pino": "^9.9.2",
		"pino-pretty": "^13.1.2"
	}
}
